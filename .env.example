# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.
# MailTrap SMTP credentials (https://mailtrap.io)
# These power email alerts from AlertManager for critical-severity alerts.
# Free tier from MailTrap is sufficient for this project.
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USERNAME=your_mailtrap_username
MAILTRAP_SMTP_PASSWORD=your_mailtrap_password
MAILTRAP_FROM_ADDRESS=football-mlops@example.com
MAILTRAP_TO_ADDRESS=ops@football-mlops.example.com

# Airflow user UID (matches host user so files stay readable)
# In production this would be a dedicated airflow service user; for local dev,
# matching your host UID prevents permission errors on bind-mounted volumes.
AIRFLOW_UID=1000
