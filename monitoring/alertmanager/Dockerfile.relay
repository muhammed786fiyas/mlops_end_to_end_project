FROM python:3.11-slim

WORKDIR /app

COPY monitoring/alertmanager/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY monitoring/alertmanager/mailtrap_relay.py ./app.py

EXPOSE 5001

# Production-grade: gunicorn with 2 workers (handles light alert load comfortably)
CMD ["gunicorn", "--bind", "0.0.0.0:5001", "--workers", "2", "--access-logfile", "-", "app:app"]
